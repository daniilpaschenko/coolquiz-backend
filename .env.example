# ── Сервер ───────────────────────────────────────────────────────────────────
PORT=3000

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/coolquiz

# ── JWT ──────────────────────────────────────────────────────────────────────
# Генерация: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_here

# ── SMTP (Email) ─────────────────────────────────────────────────────────────
# Для разработки можно использовать Mailtrap: https://mailtrap.io
# Для продакшна: Gmail, Resend, Postmark, Brevo и т.д.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# ── Клиент (фронтенд) ────────────────────────────────────────────────────────
# Используется в ссылках в письмах
CLIENT_URL=http://localhost:3000


# ── Примеры для популярных провайдеров ───────────────────────────────────────

# Gmail (нужно включить "App passwords" в Google Account):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx   # App password, не обычный пароль

# Resend (рекомендуется для продакшна, бесплатный tier 3000 писем/мес):
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxx       # API key из dashboard Resend

# SUPABASE (Bucket)
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# REDIS
REDIS_URL=redis://user:password@endpoint:port